{
  "name": "src",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon app.js",
    "start": "node app.js",
    "test": "node --test",
    "test:system": "node --test test/*.test.js",
    "test:notifications": "node --test test/notification.service.test.js",
    "dataset:training": "npm run db:generate && node modules/ai-recommendation-service/generate-training-dataset.js",
    "dataset:training:json": "npm run db:generate && node modules/ai-recommendation-service/generate-training-dataset.js --format json --output /app/ml/training.json --negatives-per-positive 2",
    "dataset:training:jsonl": "npm run db:generate && node modules/ai-recommendation-service/generate-training-dataset.js --format jsonl --output /app/ml/training_data.jsonl --negatives-per-positive 2",
    "seed": "npm run db:generate && node seed.js",
    "seed:interactions": "npm run db:generate && node seed.js --interactions-only",
    "ml:sync:legacy": "python3 ../ml/pipelines/sync_embeddings.py",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
  
    "db:migrate": "prisma migrate deploy --schema ../Database/prisma/schema.prisma --config ../Database/prisma.config.cjs",
    "db:migrate:dev": "prisma migrate dev --schema ../Database/prisma/schema.prisma --config ../Database/prisma.config.cjs",
    "seed": "node seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.98.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.58.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.2.0",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.0",
    "nodemailer": "^8.0.1",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "prisma": "^7.4.2",
    "redis": "^4.7.1",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
