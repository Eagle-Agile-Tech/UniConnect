NODE_ENV=development
PORT=3000
API_HOST_PORT=3000
DB_HOST_PORT=5434
REDIS_HOST_PORT=6380

# Core services
DATABASE_URL=postgresql://postgres:postgres@db:5432/uniconnect?schema=public
SHADOW_DATABASE_URL=postgresql://postgres:postgres@db:5432/uniconnect_shadow?schema=public
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# Auth
JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROFILE_BUCKET=profile-images
SUPABASE_ID_VERIFICATION_BUCKET=id-verifications
SUPABASE_INSTITUTION_VERIFICATION_BUCKET=institution-verification

# Mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@uniconnect.local

# Payment
CHAPA_SECRET_KEY=
CHAPA_BASE_URL=https://api.chapa.co/v1

# Client URL for callbacks
FRONTEND_URL=http://localhost:5173

# Optional admin seeding
ADMIN_EMAIL=admin@uniconnect.com
ADMIN_PASSWORD=change_me

# Optional moderation integration
GROQ_API_KEY=
MODERATION_ENABLED=false
